{
  "name": "fuel-stations-spain-api",
  "version": "1.10.4",
  "description": "REST API that provides realtime information about fuel prices in Spain",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/JGeek00/fuel-stations-spain-api.git"
  },
  "main": "index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon",
    "build:dev": "tsc && tsc-alias",
    "bump-version:major": "node scripts/bump-version.js major",
    "bump-version:major:beta": "node scripts/bump-version.js major beta",
    "bump-version:minor": "node scripts/bump-version.js minor",
    "bump-version:minor:beta": "node scripts/bump-version.js minor beta",
    "bump-version:bugfix": "node scripts/bump-version.js bugfix",
    "bump-version:bugfix:beta": "node scripts/bump-version.js bugfix beta",
    "bump-version:beta": "node scripts/bump-version.js beta",
    "build:prod": "pnpm run build:prod:compile && pnpm run build:prod:obfuscate",
    "build:prod:compile": "tsc --sourceMap false --declaration false --declarationMap false && tsc-alias",
    "build:prod:obfuscate": "node scripts/obfuscate.js",
    "prepare": "ts-patch install"
  },
  "author": "JGeek00",
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/helmet": "4.0.0",
    "@types/luxon": "3.7.1",
    "@types/node": "25.5.0",
    "javascript-obfuscator": "5.4.1",
    "nodemon": "3.1.14",
    "ts-patch": "3.3.0",
    "tsc-alias": "1.8.16",
    "tsconfig-paths": "4.2.0",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@sentry/node": "10.48.0",
    "@sentry/profiling-node": "10.48.0",
    "axios": "1.15.0",
    "cors": "2.8.6",
    "cron": "4.4.0",
    "dotenv": "17.4.0",
    "express": "5.2.1",
    "express-validator": "7.3.2",
    "helmet": "8.1.0",
    "luxon": "3.7.2",
    "pg": "8.20.0",
    "sequelize": "6.37.8",
    "sqlite3": "6.0.1",
    "ts-node": "10.9.2",
    "typia": "11.0.3"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "onFail": "error"
    }
  }
}
